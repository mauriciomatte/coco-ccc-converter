{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "out-tools",
    "rootDir": ".",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": ["node"]
  },
  "include": [
    "tools/inspect.ts",
    "tools/os9probe.ts",
    "src/main/converter/cas.ts",
    "src/main/converter/dsk.ts",
    "src/main/converter/bin.ts",
    "src/main/converter/wav.ts",
    "src/main/converter/bootstrap.ts",
    "src/main/converter/export.ts",
    "src/main/converter/os9.ts",
    "src/main/converter/dragondos.ts"
  ]
}
